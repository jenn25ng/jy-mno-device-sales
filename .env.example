# ── Polaris Colab Data Gateway 인증 (사내 자산화 발급) ──────────────────────
# Polaris 포털 ENV_VARS에 소문자 4종 주입 권장. 로컬 개발은 이 파일을 .env로 복사.
# 값이 비면 backend는 자동으로 mock 모드로 동작 (gateway 호출 안 함).
auth_key=
user_id=
app_name=mno-device-sales
database=sandbox_db_max

# ── 데이터 소스 테이블 ──────────────────────────────────────────────────────
# 최종 집계 마트. database.table 형식 또는 SUMMARY_TABLE_NAME만 줘도 됨.
SOURCE_TABLE=sandbox_db_max.device_sales_summary_daily
# 또는: SUMMARY_TABLE_NAME=device_sales_summary_daily  (database와 조합)

# ── 동작 옵션 ───────────────────────────────────────────────────────────────
# 기준월 (YYYYMM). 비우면 전월 자동.
CURRENT_EXEC_YM=
# 자동 refresh 주기 (시간)
DATA_REFRESH_INTERVAL_HOURS=6
# 수동 refresh 보호 토큰 (비우면 /api/refresh 비활성화)
ADMIN_TOKEN=
# CORS 허용 오리진 (기본 *)
FRONTEND_ORIGIN=*
# 강제로 mock 모드 (auth_key 있어도 gateway 안 씀)
USE_MOCK=
