# ════════════════════════════════════════════════════════════════════════════
# MNO Device Sales Dashboard — 환경변수 예시
# (mno-ltv-monitor와 동일한 Polaris Data Gateway 패턴. ⚠️ 직접 boto3/Athena 아님)
# ⚠️ PLACEHOLDER 값은 사용자가 실제 값으로 교체.
# ════════════════════════════════════════════════════════════════════════════

# ── [Polaris 표준 4종 — 모두 필수, default 없음] ─────────────────
# 우선순위 (어느 한 이름만 있으면 됨): 소문자 > 대문자 > DATA_GATEWAY_*
# 누락 시 fetch 시점에 명확한 에러. auth_key 비면 자동 mock 모드(gateway 미호출).
auth_key=PLACEHOLDER_AUTH_KEY_REPLACE_ME                 # 자산화 완료 후 발급받은 키
app_name=mno-device-sales                                # Polaris 앱 이름
user_id=PLACEHOLDER_USER_ID_REPLACE_ME                   # 사용자 ID (예: 1112917)
database=sandbox_db_max                                   # 자산화된 DB 이름

# ── 마트 테이블 (DATABASE + MART_TABLE_NAME → 'db.table' 조합) ──
MART_TABLE_NAME=device_sales_summary_daily
# (대안) 단일 env로도 가능: SOURCE_TABLE=sandbox_db_max.device_sales_summary_daily

# Data Gateway base URL (변경 거의 없음)
DATA_GATEWAY_URL=https://polaris-colab.sktelecom.com/api/data-gateway

# ── 기준월 파티션 ──────────────────────────────────────────────
# 비우면 직전 월 자동 (예: 오늘 2026-06 → 202605). 명시 예: CURRENT_EXEC_YM=202605
CURRENT_EXEC_YM=

# ── 동작 옵션 ──────────────────────────────────────────────────
DATA_REFRESH_INTERVAL_HOURS=6
ADMIN_TOKEN=                                              # 비우면 POST /api/refresh 비활성화
FRONTEND_ORIGIN=*
LOG_LEVEL=INFO
# auth_key가 있어도 강제로 mock 데이터 쓰려면 1
USE_MOCK=

# ── 참고: 직접 Athena(boto3) 접근은 이 프로젝트 패턴이 아님 ─────
# mno-ltv-monitor와 동일하게 Data Gateway가 Athena 쿼리를 대행하므로
# AWS_REGION / ATHENA_OUTPUT_LOCATION / AWS 키는 사용하지 않습니다.
# 만약 사내 정책상 직접 boto3 접근이 필요하면 알려주세요(데이터 계층 교체 필요).
