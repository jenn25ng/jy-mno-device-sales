# ════════════════════════════════════════════════════════════════════════════
# MNO Device Sales Dashboard — 환경변수 예시
# 데이터 접근: awswrangler(wr.athena) 직접 Athena 조회 → startup에 메모리(pandas) 적재.
# auth_key/Gateway 아님. AWS 자격증명은 표준 방식(인스턴스 역할/AWS_PROFILE/키 env) 사용.
# ⚠️ PLACEHOLDER 는 사용자가 실제 값으로 교체. 값 비면 자동 mock 모드.
# ════════════════════════════════════════════════════════════════════════════

# ── Athena / 데이터 마트 ────────────────────────────────────────
AWS_REGION=ap-northeast-2
ATHENA_OUTPUT_LOCATION=s3://PLACEHOLDER-athena-results-bucket/path/
DATABASE=sandbox_db_max
MART_TABLE_NAME=device_sales_summary_daily2
# (대안) 단일 env: SOURCE_TABLE=sandbox_db_max.device_sales_summary_daily2

# ── 메모리 캐시 윈도우 ──────────────────────────────────────────
# startup에 마트 최근 N개월을 메모리에 적재 (SQL WHERE와 일치, 마트 SQL v3.3 = 24개월)
DATA_WINDOW_MONTHS=24

# ── 동작 옵션 ───────────────────────────────────────────────────
# 1이면 Athena 미사용, 결정론적 mock DataFrame으로 동작 (로컬/화면 개발).
# ATHENA_OUTPUT_LOCATION 미설정 시에도 자동 mock.
USE_MOCK=
FRONTEND_ORIGIN=*
LOG_LEVEL=INFO
# POST /api/refresh 보호 토큰 (비우면 토큰 없이 호출 허용)
ADMIN_TOKEN=
