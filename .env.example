# ════════════════════════════════════════════════════════════════════════════
# MNO Device Sales Dashboard — 환경변수 예시
# 데이터 접근: Polaris Data Gateway (auth_key 인증). output location/AWS 자격증명 불필요.
# Gateway가 자기 workgroup·결과버킷으로 Athena를 돌리고 결과를 API로 돌려줌.
# ⚠️ PLACEHOLDER 는 사용자가 실제 값으로 교체. auth_key 비면 자동 mock 모드.
# ════════════════════════════════════════════════════════════════════════════

# ── Polaris Data Gateway 4종 (소문자 권장: 소문자 > 대문자 > DATA_GATEWAY_*) ──
auth_key=PLACEHOLDER_AUTH_KEY_REPLACE_ME    # 자산화 발급 키 (이것만 있으면 됨)
user_id=PLACEHOLDER_USER_ID_REPLACE_ME      # 사용자 ID (예: 1112917)
app_name=mno-device-sales                    # Polaris 배포 앱 이름
database=obt_encore_max                       # 자산화된 DB 이름

# ── 마트 테이블 (DATABASE + MART_TABLE_NAME → 'db.table') ──────
MART_TABLE_NAME=device_sales_summary_daily2
# (대안) 단일 env: SOURCE_TABLE=obt_encore_max.device_sales_summary_daily2

# Data Gateway base URL (변경 거의 없음)
DATA_GATEWAY_URL=https://polaris-colab.sktelecom.com/api/data-gateway

# ── 메모리 캐시 윈도우 ──────────────────────────────────────────
# 마트 SQL v3.3이 24개월로 윈도잉되어 있으므로 앱은 SELECT * (참고용 표기)
DATA_WINDOW_MONTHS=24

# ── 동작 옵션 ───────────────────────────────────────────────────
# 1이면 Gateway 미사용, 결정론적 mock DataFrame으로 동작 (로컬/화면 개발).
# auth_key 미설정 시에도 자동 mock.
USE_MOCK=
FRONTEND_ORIGIN=*
LOG_LEVEL=INFO
# POST /api/refresh 보호 토큰 (비우면 토큰 없이 호출 허용)
ADMIN_TOKEN=
